# MuseTalk Docker Image for RunPod
# Pre-built image with all model weights downloaded
# Build: docker build -t musetalk:latest .
# Push: docker push your-registry/musetalk:latest

FROM nvidia/cuda:11.8.0-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV FFMPEG_PATH=/usr/bin/ffmpeg

# System dependencies
RUN apt-get update && apt-get install -y \
    python3.10 \
    python3-pip \
    python3.10-venv \
    git \
    wget \
    curl \
    ffmpeg \
    libgl1-mesa-glx \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace/musetalk

# Clone MuseTalk
RUN git clone https://github.com/TMElyralab/MuseTalk.git . && \
    git checkout v1.5

# Python dependencies
RUN pip3 install --no-cache-dir \
    torch==2.0.1 \
    torchvision==0.15.2 \
    torchaudio==2.0.2 \
    --index-url https://download.pytorch.org/whl/cu118

RUN pip3 install --no-cache-dir -r requirements.txt

# MMLab ecosystem
RUN pip3 install --no-cache-dir -U openmim && \
    mim install mmengine && \
    mim install "mmcv==2.0.1" && \
    mim install "mmdet==3.1.0" && \
    mim install "mmpose==1.1.0"

# Download model weights
RUN mkdir -p models && \
    wget -q https://huggingface.co/TMElyralab/MuseTalk/resolve/main/musetalkV15/unet.pth -O models/musetalkV15/unet.pth && \
    wget -q https://huggingface.co/TMElyralab/MuseTalk/resolve/main/musetalkV15/musetalk.json -O models/musetalkV15/musetalk.json && \
    wget -q https://huggingface.co/ByteDance/LatentSync/resolve/main/latentsync_syncnet.pt -O models/syncnet/latentsync_syncnet.pt && \
    wget -q https://huggingface.co/yzd-v/DWPose/resolve/main/dw-ll_ucoco_384.pth -O models/dwpose/dw-ll_ucoco_384.pth && \
    wget -q https://huggingface.co/stabilityai/sd-vae-ft-mse/resolve/main/config.json -O models/sd-vae/config.json && \
    wget -q https://huggingface.co/stabilityai/sd-vae-ft-mse/resolve/main/diffusion_pytorch_model.bin -O models/sd-vae/diffusion_pytorch_model.bin && \
    wget -q https://huggingface.co/openai/whisper-tiny/resolve/main/config.json -O models/whisper/config.json && \
    wget -q https://huggingface.co/openai/whisper-tiny/resolve/main/pytorch_model.bin -O models/whisper/pytorch_model.bin && \
    wget -q https://huggingface.co/openai/whisper-tiny/resolve/main/preprocessor_config.json -O models/whisper/preprocessor_config.json

# Face parsing weights (these need special handling - from Google Drive)
# You may need to download these manually and COPY them in
# RUN wget -q ... -O models/face-parse-bisent/79999_iter.pth
# RUN wget -q https://download.pytorch.org/models/resnet18-5c106cde.pth -O models/face-parse-bisent/resnet18-5c106cde.pth

# Create directories
RUN mkdir -p /workspace/musetalk/results /workspace/musetalk/configs/inference

CMD ["/bin/bash", "-c", "sleep infinity"]
